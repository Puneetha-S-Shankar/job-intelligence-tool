# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# AI — active provider: Gemini (free tier, get key at aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# AI — future provider: Claude (uncomment in src/services/ai/index.ts to activate)
CLAUDE_API_KEY=leave_blank_for_now

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com

# App
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Optional: URL of external job feed / API
JOB_SOURCE_URL=https://example-job-api.com/jobs
