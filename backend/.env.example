# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# AI — active provider: Gemini (free tier, get key at aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# AI — future provider: Claude (uncomment in src/services/ai/index.ts to activate)
CLAUDE_API_KEY=leave_blank_for_now

# Email — Nodemailer (Gmail SMTP)
# EMAIL_PASS must be a Google App Password (Google Account → Security → 2-Step → App passwords),
# not your normal Gmail password.
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_16_digit_google_app_password
DIRECTOR_EMAIL=director@rvu.edu.in

# App
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# SerpAPI — Google Jobs engine for live search + daily company LinkedIn refresh
# https://serpapi.com — required for GET /api/jobs/search live results & scheduler Step 1
SERP_API_KEY=
